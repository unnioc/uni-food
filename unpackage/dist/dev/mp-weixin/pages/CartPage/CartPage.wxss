.cart-container {
  width: 100%;
  background-color: #fff;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}
.header-action {
  padding: 20rpx 20rpx 0 20rpx;
  text-align: right;
  display: flex;
  justify-content: space-between;
}
.header-action .select-btn {
  font-size: 28rpx;
  font-weight: bold;
  color: #42b983;
}
.header-action .clear-btn {
  font-size: 28rpx;
  color: #999;
}
.cart-list {
  flex: 1;
  width: 95%;
  height: 90%;
  padding: 16rpx;
  padding-bottom: 200rpx;
}
.cart-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}
.cart-item .item-checkbox {
  transform: scale(0.8);
}
.cart-item .item-body {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-left: 20rpx;
}
.cart-item .item-body .food-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  display: block;
}
.cart-item .item-body .food-price {
  font-size: 28rpx;
  color: #42b983;
  margin-top: 8rpx;
  display: block;
}
.stepper {
  display: flex;
  align-items: center;
  border: 1rpx solid #efefef;
  border-radius: 12rpx;
  overflow: hidden;
}
.stepper .step-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  background-color: #fff;
  color: #ccc;
}
.stepper .step-btn.plus {
  color: #42b983;
}
.stepper .step-btn:active {
  background-color: #f9f9f9;
}
.stepper .step-num {
  width: 70rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 30rpx;
  border-left: 1rpx solid #efefef;
  border-right: 1rpx solid #efefef;
}
.footer-bar {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  padding: 20rpx 20rpx 0 20rpx;
  background-color: #fff;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 999;
  padding-bottom: 20rpx;
}
.footer-bar .total-info .total-label {
  font-size: 24rpx;
  color: #999;
  display: block;
}
.footer-bar .total-info .total-amount {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a1a;
}
.footer-bar .checkout-btn {
  background-color: #42b983;
  color: #fff;
  border-radius: 20rpx;
  width: 320rpx;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 32rpx;
  margin: 0;
}
.footer-bar .checkout-btn::after {
  border: none;
}
.empty-cart {
  padding-top: 200rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.empty-cart image {
  width: 400rpx;
  height: 400rpx;
}
.empty-cart .empty-tip {
  margin-top: 20rpx;
  text-align: center;
  color: #999;
}
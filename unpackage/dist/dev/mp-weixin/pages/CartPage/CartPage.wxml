<view class="cart-container"><view class="header-action"><text class="select-btn" bindtap="{{a}}">全选</text><text class="clear-btn" bindtap="{{b}}">清空</text></view><scroll-view scroll-y class="cart-list"><view wx:for="{{c}}" wx:for-item="item" wx:key="h" class="cart-item"><checkbox checked="{{item.a}}" color="#42b983" bindtap="{{item.b}}" class="item-checkbox"/><view class="item-body"><view class="info-left"><text class="food-name">{{item.c}}</text><text class="food-price">￥{{item.d}}</text></view><view class="stepper"><view class="step-btn minus" bindtap="{{item.e}}">-</view><text class="step-num">{{item.f}}</text><view class="step-btn plus" bindtap="{{item.g}}">+</view></view></view></view><view wx:if="{{d}}" class="empty-cart"><image src="{{e}}" mode=""></image><view class="empty-tip">您的购物车空空如也</view></view></scroll-view><view class="footer-bar"><view class="total-info"><text class="total-label">总金额</text><text class="total-amount">￥{{f}}</text></view><button class="checkout-btn" bindtap="{{g}}">前往结账</button></view></view>
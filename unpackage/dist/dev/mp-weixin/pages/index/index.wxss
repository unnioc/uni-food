.container {
  background-color: #f9f9f9;
  min-height: 100vh;
  padding-bottom: 20rpx;
}
.search-header {
  padding: 20rpx 30rpx;
}
.search-header .search-bar {
  background-color: #ffffff;
  height: 70rpx;
  border-radius: 35rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}
.search-header .search-bar .placeholder {
  font-size: 26rpx;
  color: #999;
  margin-left: 10rpx;
}
.banner-swiper {
  height: 300rpx;
  margin: 20rpx 30rpx;
}
.banner-swiper .banner-image {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
}
.category-scroll {
  white-space: nowrap;
  padding: 10rpx 30rpx;
}
.category-scroll .category-item {
  display: inline-block;
  padding: 12rpx 35rpx;
  background-color: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
  margin-right: 20rpx;
}
.category-scroll .category-item.active {
  background-color: #42b983;
  color: #fff;
}
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  padding: 30rpx;
}
.food-list {
  padding: 0 30rpx;
}
.food-list .food-card {
  background-color: #fff;
  border-radius: 20rpx;
  display: flex;
  padding: 20rpx;
  margin-bottom: 20rpx;
}
.food-list .food-card .food-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}
.food-list .food-card .food-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.food-list .food-card .food-info .food-name {
  font-size: 30rpx;
  font-weight: 500;
}
.food-list .food-card .food-info .food-desc {
  font-size: 24rpx;
  color: #999;
}
.food-list .food-card .food-info .food-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.food-list .food-card .food-info .food-bottom .food-price {
  color: #ff5252;
  font-size: 32rpx;
  font-weight: bold;
}
.food-list .food-card .food-info .food-bottom .add-btn {
  background-color: #42b983;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.food-list .food-card .food-info .food-bottom .add-btn .plus {
  color: #fff;
  font-size: 32rpx;
  margin-top: -4rpx;
}
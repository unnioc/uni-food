.profile-container {
  background-color: #fcfcfc;
  min-height: 100vh;
}
.user-header {
  background-color: #fff;
  padding: 80rpx 0 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.user-header .avatar-box {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 6rpx solid #e8f7f0;
  overflow: hidden;
  margin-bottom: 30rpx;
}
.user-header .avatar-box .avatar {
  width: 100%;
  height: 100%;
}
.user-header .user-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}
.user-header .user-email {
  font-size: 26rpx;
  color: #999;
}
.menu-list {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 0 30rpx;
}
.menu-list .menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 35rpx 10rpx;
  border-bottom: 1rpx solid #f8f8f8;
}
.menu-list .menu-item:last-child {
  border-bottom: none;
}
.menu-list .menu-item .item-left {
  display: flex;
  align-items: center;
}
.menu-list .menu-item .item-left .item-title {
  font-size: 30rpx;
  color: #333;
  margin-left: 20rpx;
}
.menu-list .menu-item:active {
  background-color: #f9f9f9;
}
.logout-section {
  padding: 60rpx 40rpx;
}
.logout-section .logout-btn {
  background-color: #fff;
  color: #ff5252;
  border: 2rpx solid #ff5252;
  border-radius: 20rpx;
  font-size: 32rpx;
  height: 90rpx;
  line-height: 90rpx;
  font-weight: 500;
}
.logout-section .logout-btn::after {
  border: none;
}
.logout-section .logout-btn:active {
  background-color: #fff1f1;
}
<view class="detail-container"><view class="status-header"><view class="status-icon"><icon type="success" size="40" color="#42b983"/></view><text class="status-text">订单完成</text><text class="shop-name">The Uni Food</text></view><view class="section-box"><view class="section-title title"><image src="{{a}}"></image><view>已下单菜品</view></view><view wx:for="{{b}}" wx:for-item="item" wx:key="d" class="food-item"><view class="food-left"><text class="food-name">{{item.a}}</text><text class="food-num">x{{item.b}}</text></view><text class="food-price">￥{{item.c}}</text></view></view><view class="section-box cost-details"><view class="cost-row"><text>合计</text><text>￥{{c}}</text></view><view class="cost-row"><text>配送费</text><text>￥{{d}}</text></view><view class="cost-row total-row"><text class="total-label">总金额</text><text class="total-val">￥{{e}}</text></view></view><view class="section-box info-section"><view class="title section-title"><image src="{{f}}"></image><view>订单信息</view></view><view class="info-item"><text class="info-label">订单 ID</text><text class="info-val">#{{g}}</text></view><view class="info-item"><text class="info-label">创建时间</text><text class="info-val">{{h}}</text></view><view class="info-item"><text class="info-label">收货地址 </text><text class="info-val">{{i}}</text></view></view></view>
.detail-container {
  background-color: #fff;
  min-height: 100vh;
  padding: 40rpx 0;
}
.status-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  border-bottom: 2rpx solid #f8f8f8;
}
.status-header .status-icon {
  background-color: #e8f7f0;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}
.status-header .status-text {
  font-size: 44rpx;
  font-weight: bold;
  color: #1a1a1a;
}
.status-header .shop-name {
  font-size: 28rpx;
  color: #888;
  margin-top: 10rpx;
}
.section-box {
  padding: 30rpx 40rpx;
  border-bottom: 2rpx solid #f8f8f8;
}
.section-box .section-title {
  font-size: 24rpx;
  color: #999;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  margin-bottom: 30rpx;
}
.food-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 30rpx;
}
.food-item .food-name {
  font-size: 30rpx;
  color: #333;
  display: block;
}
.food-item .food-num {
  font-size: 26rpx;
  color: #999;
  margin-top: 6rpx;
}
.food-item .food-price {
  font-size: 30rpx;
  font-weight: 500;
}
.cost-details .cost-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: #666;
}
.cost-details .total-row {
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #f0f0f0;
}
.cost-details .total-row .total-label {
  font-size: 34rpx;
  font-weight: bold;
  color: #1a1a1a;
}
.cost-details .total-row .total-val {
  font-size: 34rpx;
  font-weight: bold;
  color: #42b983;
}
.title {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.title image {
  width: 35rpx;
  height: 35rpx;
}
.info-section .info-item {
  margin-bottom: 30rpx;
}
.info-section .info-item .info-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}
.info-section .info-item .info-val {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}
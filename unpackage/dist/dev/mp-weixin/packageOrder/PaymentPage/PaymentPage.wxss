.checkout-container {
  background-color: #f8f9fa;
  min-height: 100vh;
  padding: 30rpx;
  padding-bottom: 200rpx;
}
.card-box {
  background-color: #fff;
  border-radius: 30rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
}
.card-box .card-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}
.card-box .card-header .header-title {
  font-size: 24rpx;
  color: #909399;
  font-weight: bold;
  margin-left: 10rpx;
  letter-spacing: 1rpx;
}
.address-content .user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}
.address-content .address-detail {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  display: block;
  margin-bottom: 10rpx;
}
.address-content .user-phone {
  font-size: 28rpx;
  color: #999;
}
.summary-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 25rpx;
  font-size: 30rpx;
  color: #444;
}
.summary-item.delivery-fee {
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #f2f2f2;
  color: #888;
}
.payment-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  transition: all 0.2s;
}
.payment-item.active {
  border-color: #42b983;
  background-color: rgba(66, 185, 131, 0.02);
}
.payment-item .pay-left {
  display: flex;
  align-items: center;
}
.payment-item .pay-left .pay-name {
  margin-left: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
}
.payment-item .radio-circle {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.payment-item .radio-circle .inner-dot {
  width: 20rpx;
  height: 20rpx;
  background-color: #42b983;
  border-radius: 50%;
}
.payment-item.active .radio-circle {
  border-color: #42b983;
}
.footer-pay-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 30rpx 40rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 -10rpx 30rpx rgba(0, 0, 0, 0.03);
}
.footer-pay-bar .total-section .label {
  font-size: 24rpx;
  color: #999;
  display: block;
}
.footer-pay-bar .total-section .amount {
  font-size: 40rpx;
  font-weight: bold;
  color: #42b983;
}
.footer-pay-bar .pay-btn {
  background-color: #42b983;
  color: #fff;
  border: none;
  border-radius: 24rpx;
  width: 340rpx;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 34rpx;
  font-weight: bold;
  margin: 0;
}
.footer-pay-bar .pay-btn::after {
  border: none;
}
.footer-pay-bar .pay-btn:active {
  opacity: 0.9;
}